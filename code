        self.un.setMinimumHeight(42); cl.addWidget(self.un); cl.addSpacing(8)
        cl.addWidget(blbl("Password")); self.pw=QLineEdit(); self.pw.setPlaceholderText("Enter password")
        self.pw.setEchoMode(QLineEdit.EchoMode.Password); self.pw.setMinimumHeight(42)
        self.pw.returnPressed.connect(self._login); cl.addWidget(self.pw); cl.addSpacing(18)
        lb=QPushButton("Login"); lb.setMinimumHeight(46); lb.setFont(QFont("Segoe UI",13,QFont.Weight.Bold))
        lb.clicked.connect(self._login); cl.addWidget(lb); cl.addSpacing(10)
        self.err=QLabel(""); self.err.setAlignment(Qt.AlignmentFlag.AlignCenter)
        self.err.setStyleSheet(f"color:{TIP_RED};background:transparent;font-weight:bold;"); cl.addWidget(self.err)
        cl.addStretch()
        hint=QLabel("Demo: admin/admin123  ·  staff1/staff123  ·  nurse1/nurse123")
        hint.setAlignment(Qt.AlignmentFlag.AlignCenter)
        hint.setStyleSheet(f"color:{TIP_MUTED};font-size:10px;background:transparent;"); cl.addWidget(hint)
