def db_auth(u, p):
    rows = _db().executequery(
        "SELECT * FROM users WHERE username=%s AND password=%s", (u, p)
    )
    return rows[0] if rows else None

def db_users():
    return _db().executequery("SELECT * FROM users ORDER BY role, username")

def db_add_user(un, pw, role, fn):
    try:
        conn = pymysql.connect(**{k: DB_CONFIG[k] for k in ("host","port","user","password","db")},
                               autocommit=False)
        cur = conn.cursor()
        cur.execute(
            "INSERT INTO users (username,password,role,full_name) VALUES (%s,%s,%s,%s)",
            (un, pw, role, fn)
        )
        conn.commit(); conn.close(); return True
    except pymysql.IntegrityError:
        return False
    except pymysql.MySQLError as e:
        print(e); return False

