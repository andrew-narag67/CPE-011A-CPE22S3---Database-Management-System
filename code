        fl=QHBoxLayout(foot); fl.setContentsMargins(12,0,12,0)
        fv=QLabel("SCDS v1.0  |  Group 3  |  CPE 011"); fv.setStyleSheet("color:#8aafd4;font-size:10px;background:transparent;")
        fl.addStretch(); fl.addWidget(fv); fl.addStretch(); vl.addWidget(foot)

    def _login(self):
        un=self.un.text().strip(); pw=self.pw.text()
        if not un or not pw: self.err.setText("Enter username and password."); return
        user=db_auth(un,pw)
        if not user: self.err.setText("Invalid username or password."); self.pw.clear(); return
        self.hide(); role=user["role"]
        if   role=="Admin": self._rw=AdminWin(user,self._logout)
        elif role=="Staff": self._rw=StaffWin(user,self._logout)
        else:               self._rw=NurseWin(user,self._logout)
        self._rw.show()

    def _logout(self):
        if self._rw: self._rw.close(); self._rw=None
        self.un.clear(); self.pw.clear(); self.err.clear(); self.show()

