        self.tbl.setHorizontalHeaderLabels(["Student ID","Full Name","Course","Year","Blood","Allergies"])
        self.tbl.horizontalHeader().setSectionResizeMode(QHeaderView.ResizeMode.Stretch)
        self.tbl.setSelectionBehavior(QTableWidget.SelectionBehavior.SelectRows)
        self.tbl.setEditTriggers(QTableWidget.EditTrigger.NoEditTriggers)
        self.tbl.setAlternatingRowColors(True); self.tbl.setStyleSheet("alternate-background-color:#EEF2FA;")
        self.tbl.doubleClicked.connect(self._open); lay.addWidget(self.tbl)
        hint=QLabel("Double-click a student to view / manage consultations.")
        hint.setStyleSheet(f"color:{TIP_MUTED};font-size:11px;background:transparent;"); lay.addWidget(hint)
        if self.can_edit:
            rb=QHBoxLayout()
            eb=QPushButton("✏  Edit Student"); eb.clicked.connect(self._edit); rb.addWidget(eb)
            db=QPushButton("🗑  Delete Student"); db.setObjectName("red"); db.clicked.connect(self._del); rb.addWidget(db)
            rb.addStretch(); lay.addLayout(rb)

    def _load(self):
        self.students=db_students(); self._pop(self.students)

    def _pop(self, lst):
        self.tbl.setRowCount(len(lst))
        for r,s in enumerate(lst):
            for col,k in enumerate(["student_id","full_name","course","year_level","blood_type","known_allergies"]):
                self.tbl.setItem(r,col,QTableWidgetItem(s.get(k) or ""))

    def _filter(self,t):
        t=t.lower()
        self._pop([s for s in self.students if t in s.get("full_name","").lower()
                   or t in s.get("student_id","").lower() or t in s.get("course","").lower()])

    def _sel(self):
        row=self.tbl.currentRow()
        if row<0: return None
        sid=self.tbl.item(row,0).text()
        return next((s for s in self.students if s["student_id"]==sid),None)

    def _add(self):
        dlg=StudentDlg(self,existing_ids=[s["student_id"] for s in self.students])
        if dlg.exec(): db_save_student(dlg.data()); self._load()

    def _edit(self):
        s=self._sel()
        if not s: QMessageBox.information(self,"Info","Select a student."); return
        dlg=StudentDlg(self,student=s)
        if dlg.exec(): db_save_student(dlg.data()); self._load()

    def _del(self):
        s=self._sel()
        if not s: QMessageBox.information(self,"Info","Select a student."); return
        if QMessageBox.question(self,"Confirm",
                f"Delete '{s['full_name']}' and ALL records?",
                QMessageBox.StandardButton.Yes|QMessageBox.StandardButton.No)==QMessageBox.StandardButton.Yes:
            db_del_student(s["student_id"]); self._load()

    def _open(self):
        s=self._sel()
        if not s: return
        dlg=QDialog(self); dlg.setWindowTitle(f"Consultations — {s['full_name']}")
        dlg.resize(900,600); dlg.setStyleSheet(GSS)
        lay=QVBoxLayout(dlg); lay.addWidget(ConPanel(s,can_edit=self.can_edit))
        cb=QPushButton("Close"); cb.clicked.connect(dlg.close); lay.addWidget(cb)
        dlg.exec()

