        self.rb_clinic.clicked.connect(lambda: self._switch_mode(False))
        self.rb_student.clicked.connect(lambda: self._switch_mode(True))

        lay.addWidget(mode_box)

        # Student selector
        self.student_box = QGroupBox("Select Student")
        sb_lay = QVBoxLayout(self.student_box); sb_lay.setSpacing(8)

        self.rep_srch = QLineEdit(); self.rep_srch.setPlaceholderText("🔍  Search by name or ID...")
        self.rep_srch.setMinimumHeight(36); self.rep_srch.textChanged.connect(self._filter_students)
        sb_lay.addWidget(self.rep_srch)

        self.rep_list = QListWidget(); self.rep_list.setMaximumHeight(200)
        self.rep_list.setStyleSheet(f"""
            QListWidget {{border:1.5px solid {TIP_BORD};border-radius:6px;background:white;font-size:12px;}}
            QListWidget::item {{padding:8px 12px;border-bottom:1px solid {TIP_BORD};}}
            QListWidget::item:selected {{background:{TIP_BLUE};color:white;}}
            QListWidget::item:hover {{background:#EEF2FA;}}
        """)
        sb_lay.addWidget(self.rep_list)

        self._all_students = []
        self._reload_students()

        self.student_box.setVisible(False)   # default: clinic summary mode
        lay.addWidget(self.student_box)

        # Generate Button
        gen_row = QHBoxLayout()
        self.gen_btn = QPushButton("📄  Generate & Save PDF")
        self.gen_btn.setObjectName("gold"); self.gen_btn.setMinimumHeight(46)
        self.gen_btn.setFont(QFont("Segoe UI", 13, QFont.Weight.Bold))
        self.gen_btn.clicked.connect(self._gen)
        gen_row.addWidget(self.gen_btn); gen_row.addStretch()
        lay.addLayout(gen_row)

        self.rsts = QLabel("")
        self.rsts.setWordWrap(True)
        self.rsts.setStyleSheet(f"color:{TIP_GREEN};background:transparent;font-weight:bold;font-size:12px;")
        lay.addWidget(self.rsts)
        lay.addStretch()

    def _switch_mode(self, student_mode):
        self.rb_clinic.setChecked(not student_mode)
        self.rb_student.setChecked(student_mode)
        self.student_box.setVisible(student_mode)
        self.rsts.setText("")

    def _reload_students(self):
        self._all_students = db_students()
        self._fill_list(self._all_students)

    def _fill_list(self, lst):
        self.rep_list.clear()
        for s in lst:
            item = QListWidgetItem(f"  {s['student_id']}  —  {s['full_name']}  ({s.get('course','')})")
            item.setData(Qt.ItemDataRole.UserRole, s)
            self.rep_list.addItem(item)

    def _filter_students(self, text):
        t = text.lower()
        self._fill_list([
            s for s in self._all_students
            if t in s.get("full_name","").lower() or t in s.get("student_id","").lower()
        ])

    def _gen(self):
        self.rsts.setText("")
        student_mode = self.rb_student.isChecked()

        if student_mode:
            sel = self.rep_list.currentItem()
            if not sel:
                QMessageBox.warning(self, "No Student Selected",
                    "Please select a student from the list."); return
            student = sel.data(Qt.ItemDataRole.UserRole)
            fname = f"SCDS_{student['student_id']}_HealthReport.pdf"
            path  = os.path.join(os.path.expanduser("~"), fname)
            try:
                gen_student_report(path, student, by=self.user["full_name"])
                self.rsts.setText(f"✅  Student report saved:\n{path}")
                QMessageBox.information(self, "Done",
                    f"Health report for {student['full_name']} saved to:\n{path}")
            except Exception as e:
                QMessageBox.critical(self, "Error", f"Failed to generate report:\n{e}")
        else:
            path = os.path.join(os.path.expanduser("~"), "SCDS_Clinic_Summary_Report.pdf")
            try:
                gen_clinic_report(path, by=self.user["full_name"])
                self.rsts.setText(f"✅  Clinic summary report saved:\n{path}")
                QMessageBox.information(self, "Done", f"Clinic summary report saved to:\n{path}")
            except Exception as e:
                QMessageBox.critical(self, "Error", f"Failed to generate report:\n{e}")


