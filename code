        del_b=QPushButton("Delete Selected"); del_b.setObjectName("red"); del_b.clicked.connect(self._del_u); br.addWidget(del_b)
        br.addStretch(); fl.addRow(br); lay.addWidget(gb); return w

    def _reload_u(self):
        self._ud=db_users(); self.utbl.setRowCount(len(self._ud))
        for r,u in enumerate(self._ud):
            self.utbl.setItem(r,0,QTableWidgetItem(str(u["id"])))
            self.utbl.setItem(r,1,QTableWidgetItem(u["username"]))
            self.utbl.setItem(r,2,QTableWidgetItem(u["full_name"] or ""))
            self.utbl.setItem(r,3,QTableWidgetItem(u["role"]))

    def _add_u(self):
        un=self.nu_un.text().strip(); pw=self.nu_pw.text()
        fn=self.nu_fn.text().strip(); role=self.nu_rl.currentText()
        if not un or not pw: QMessageBox.warning(self,"Error","Username and Password required."); return
        if db_add_user(un,pw,role,fn):
            self.nu_un.clear(); self.nu_pw.clear(); self.nu_fn.clear(); self._reload_u()
            QMessageBox.information(self,"Done",f"User '{un}' added.")
        else: QMessageBox.warning(self,"Error",f"Username '{un}' already exists.")

    def _del_u(self):
        row=self.utbl.currentRow()
        if row<0: QMessageBox.information(self,"Info","Select a user."); return
        uid=int(self.utbl.item(row,0).text()); un=self.utbl.item(row,1).text()
        if un==self.user["username"]: QMessageBox.warning(self,"Error","Cannot delete yourself."); return
        if QMessageBox.question(self,"Confirm",f"Delete user '{un}'?",
                QMessageBox.StandardButton.Yes|QMessageBox.StandardButton.No)==QMessageBox.StandardButton.Yes:
            db_del_user(uid); self._reload_u()

