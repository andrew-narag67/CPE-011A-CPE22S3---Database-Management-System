        ("INNERGRID",     (0,0),(-1,-1), 0.3, C["BORD"]),
        ("TOPPADDING",    (0,0),(-1,-1), 6),
        ("BOTTOMPADDING", (0,0),(-1,-1), 6),
        ("LEFTPADDING",   (0,0),(-1,-1), 8),
        ("RIGHTPADDING",  (0,0),(-1,-1), 8),
        ("VALIGN",        (0,0),(-1,-1), "MIDDLE"),
        # Highlight allergies row if not None/empty
        *([("BACKGROUND", (1,9),(1,9), colors.HexColor("#FFF0F0")),
           ("TEXTCOLOR",  (1,9),(1,9), C["RED"])]
          if (student.get("known_allergies","") or "").lower() not in ("","none") else []),
    ]))
    story.append(prof_tbl)
    story.append(Spacer(1, 6*mm))

    # CONSULTATION SUMMARY
    story.append(Paragraph("CONSULTATION SUMMARY", ST["SEC"]))
    badge_row = Table(
        [["Total Clinic Visits", "Most Recent Visit"],
         [str(len(cons)),
          cons[0]["date_of_visit"] if cons else "No visits on record"]],
        colWidths=[85*mm, 85*mm]
    )
    badge_row.setStyle(TableStyle([
        ("BACKGROUND",    (0,0),(-1,0),  C["BLU"]),
        ("TEXTCOLOR",     (0,0),(-1,0),  colors.white),
        ("FONTNAME",      (0,0),(-1,0),  "Helvetica-Bold"),
        ("FONTSIZE",      (0,0),(-1,0),  9),
        ("ALIGN",         (0,0),(-1,-1), "CENTER"),
        ("FONTNAME",      (0,1),(-1,1),  "Helvetica-Bold"),
        ("FONTSIZE",      (0,1),(0,1),   28),
        ("FONTSIZE",      (1,1),(1,1),   11),
        ("TEXTCOLOR",     (0,1),(-1,1),  C["BLU"]),
        ("BACKGROUND",    (0,1),(-1,1),  C["LITE"]),
        ("BOX",           (0,0),(-1,-1), 1, C["BORD"]),
        ("INNERGRID",     (0,0),(-1,-1), 0.5, C["BORD"]),
        ("TOPPADDING",    (0,0),(-1,-1), 8),
        ("BOTTOMPADDING", (0,0),(-1,-1), 8),
    ]))
    story.append(badge_row)
    story.append(Spacer(1, 6*mm))

    # CONSULTATION HISTORY
    story.append(Paragraph("CONSULTATION HISTORY", ST["SEC"]))
    if not cons:
        story.append(Paragraph("No consultation records found for this student.", ST["BODY"]))
    else:
        for i, c in enumerate(cons):
        
            visit_hdr = Table(
                [[Paragraph(
                    f"<b>Visit #{len(cons)-i}</b>  —  {c['date_of_visit']}   "
                    f"| Nurse: {c.get('nurse_on_duty','—')}",
                    ST["BOLD"]
                )]],
                colWidths=[170*mm]
            )
            visit_hdr.setStyle(TableStyle([
                ("BACKGROUND",    (0,0),(-1,-1), C["BLU"]),
                ("TEXTCOLOR",     (0,0),(-1,-1), colors.white),
                ("TOPPADDING",    (0,0),(-1,-1), 5),
                ("BOTTOMPADDING", (0,0),(-1,-1), 5),
                ("LEFTPADDING",   (0,0),(-1,-1), 8),
            ]))
            story.append(visit_hdr)

            def cfield(label, value):
                return [Paragraph(f"<b>{label}</b>", ST["BODY"]),
                        Paragraph(value or "—",       ST["BODY"])]

            fu = c.get("follow_up_date","") or ""
            detail_rows = [
                cfield("Chief Complaint",    c.get("chief_complaint","")),
                cfield("Diagnosis",          c.get("diagnosis","")),
                cfield("Treatment",          c.get("treatment","")),
                cfield("Prescribed Meds",    c.get("prescribed_meds","")),
                cfield("Nurse Notes",        c.get("nurse_notes","")),
                cfield("Follow-up Date",     fu if fu else "None"),
            ]
            det_tbl = Table(detail_rows, colWidths=[40*mm, 130*mm])
            det_tbl.setStyle(TableStyle([
                ("BACKGROUND",    (0,0),(0,-1),  C["LITE"]),
                ("TEXTCOLOR",     (0,0),(0,-1),  C["DARK"]),
                ("BOX",           (0,0),(-1,-1), 0.5, C["BORD"]),
                ("INNERGRID",     (0,0),(-1,-1), 0.3, C["BORD"]),
                ("TOPPADDING",    (0,0),(-1,-1), 5),
                ("BOTTOMPADDING", (0,0),(-1,-1), 5),
                ("LEFTPADDING",   (0,0),(-1,-1), 8),
                ("RIGHTPADDING",  (0,0),(-1,-1), 8),
                ("VALIGN",        (0,0),(-1,-1), "TOP"),
            ]))
            story.append(det_tbl)
            story.append(Spacer(1, 4*mm))

    _pdf_footer(story, C, ST)
    doc.build(story)
    return path

