class StudentDlg(QDialog):
    def __init__(self, parent=None, student=None, existing_ids=None):
        super().__init__(parent); self.student=student; self.existing=existing_ids or []
        self.setWindowTitle("Add Student" if not student else "Edit Student")
        self.setMinimumWidth(500); self.setStyleSheet(GSS); self._build()

    def _f(self, ph=""): f=QLineEdit(); f.setPlaceholderText(ph); f.setMinimumHeight(36); return f

    def _build(self):
        lay=QVBoxLayout(self); lay.setSpacing(7)
        lay.addWidget(blbl("Student ID *")); self.sid=self._f("e.g. 2412089"); lay.addWidget(self.sid)
        lay.addWidget(blbl("Full Name *")); self.nm=self._f("Last Name, First Name M.I."); lay.addWidget(self.nm)
        r=QHBoxLayout()
        c1=QVBoxLayout(); c1.addWidget(blbl("Course"))
        self.course=QComboBox(); self.course.addItems(["BSCpE","BSCS","BSIT","BSCE","BSEE","BSME","BSIE","BSARCH","Other"])
        self.course.setMinimumHeight(36); c1.addWidget(self.course); r.addLayout(c1)
        c2=QVBoxLayout(); c2.addWidget(blbl("Year Level"))
        self.year=QComboBox(); self.year.addItems(["1st Year","2nd Year","3rd Year","4th Year","5th Year"])
        self.year.setMinimumHeight(36); c2.addWidget(self.year); r.addLayout(c2); lay.addLayout(r)
        lay.addWidget(blbl("Date of Birth")); self.dob=QDateEdit(); self.dob.setCalendarPopup(True)
        self.dob.setDate(QDate(2002,1,1)); self.dob.setMinimumHeight(36); lay.addWidget(self.dob)
        lay.addWidget(blbl("Contact Number")); self.ct=self._f("09XX-XXX-XXXX"); lay.addWidget(self.ct)
        lay.addWidget(blbl("Address")); self.addr=self._f("Barangay, City/Municipality"); lay.addWidget(self.addr)
        lay.addWidget(blbl("Emergency Contact")); self.em=self._f("Name / Number"); lay.addWidget(self.em)
        r2=QHBoxLayout()
        c3=QVBoxLayout(); c3.addWidget(blbl("Blood Type"))
        self.bt=QComboBox(); self.bt.addItems(["A+","A-","B+","B-","AB+","AB-","O+","O-","Unknown"])
        self.bt.setMinimumHeight(36); c3.addWidget(self.bt); r2.addLayout(c3)
        c4=QVBoxLayout(); c4.addWidget(blbl("Known Allergies"))
        self.al=self._f("Penicillin / None"); c4.addWidget(self.al); r2.addLayout(c4); lay.addLayout(r2)
        bb=QDialogButtonBox(QDialogButtonBox.StandardButton.Ok|QDialogButtonBox.StandardButton.Cancel)
        bb.accepted.connect(self._ok); bb.rejected.connect(self.reject); lay.addWidget(bb)
        if self.student: self._load()

    def _load(self):
        s=self.student; self.sid.setText(s.get("student_id","")); self.sid.setEnabled(False)
        self.nm.setText(s.get("full_name",""))
        i=self.course.findText(s.get("course","")); self.course.setCurrentIndex(max(i,0))
        i=self.year.findText(s.get("year_level","")); self.year.setCurrentIndex(max(i,0))
        if s.get("date_of_birth"):
            d=QDate.fromString(s["date_of_birth"],"yyyy-MM-dd")
            if d.isValid(): self.dob.setDate(d)
        self.ct.setText(s.get("contact_no","")); self.addr.setText(s.get("address",""))
        self.em.setText(s.get("emergency_contact",""))
        i=self.bt.findText(s.get("blood_type","Unknown")); self.bt.setCurrentIndex(max(i,0))
        self.al.setText(s.get("known_allergies",""))

    def _ok(self):
        sid=self.sid.text().strip(); nm=self.nm.text().strip()
        if not sid: QMessageBox.warning(self,"Error","Student ID required."); return
        if not sid.isdigit() or len(sid) != 7:
            QMessageBox.warning(self,"Error","Student ID must be exactly 7 digits (e.g. 2412089)."); return
        if not nm:  QMessageBox.warning(self,"Error","Full Name required."); return
        if not self.student and sid in self.existing:
            QMessageBox.warning(self,"Error",f"ID '{sid}' already exists."); return
        self.accept()

    def data(self):
        return dict(student_id=self.sid.text().strip(),full_name=self.nm.text().strip(),
            course=self.course.currentText(),year_level=self.year.currentText(),
            date_of_birth=self.dob.date().toString("yyyy-MM-dd"),contact_no=self.ct.text().strip(),
            address=self.addr.text().strip(),emergency_contact=self.em.text().strip(),
            blood_type=self.bt.currentText(),known_allergies=self.al.text().strip())


